-- -- MonHub | Macro & Quest Only Version
-- -- Wind UI Latest
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- ========================
-- Services
-- ========================
local Players             = game:GetService("Players")
local UserInputService    = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer         = Players.LocalPlayer

-- ========================
-- State Configurations
-- ========================
-- [Quest System]
local questNpcNames = { "Kazashi", "Iceman", "Toki", "Cop", "Pickle" }
local questList     = { "Thugs", "Cyclops", "Bandits", "Cops" }
local selectedQuestNpc = "Cop"
local selectedQuest    = "Thugs"
local autoQuestEnabled = false
local autoQuestThread  = nil

-- [Macro System]
local macroData = {} -- เก็บปุ่มและเวลาที่กด
local isRecording = false
local isPlaying = false
local macroThread = nil
local startTime = 0

-- ========================
-- Universal UI Quest Clicker Logic
-- ========================
local function clickButton(button)
    if button:IsA("TextButton") or button:IsA("ImageButton") then
        pcall(function()
            for _, connection in pairs(getconnections(button.MouseButton1Click or button.Activated)) do
                connection:Fire()
            end
        end)
        pcall(function()
            button:SimulateClick()
        end)
    end
end

local function autoAcceptQuest(questName)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    for _, guiObject in ipairs(playerGui:GetDescendants()) do
        if guiObject:IsA("TextButton") or guiObject:IsA("TextLabel") then
            if guiObject.Text:lower():find(questName:lower()) then
                if guiObject:IsA("TextButton") then
                    clickButton(guiObject)
                    return true
                elseif guiObject.Parent:IsA("TextButton") or guiObject.Parent:IsA("ImageButton") then
                    clickButton(guiObject.Parent)
                    return true
                end
            end
        end
    end
    return false
end

-- ลูปการทำงานระบบรับเควสออโต้แบบสแกนจอ
local function startQuestLoop()
    if questThread then task.cancel(questThread) end
    questThread = task.spawn(function()
        while autoQuestEnabled do
            local success = autoAcceptQuest(selectedQuest)
            if success then
                WindUI:Notify({
                    Title = "Quest System",
                    Content = "คลิกรับเควส [" .. selectedQuest .. "] บนหน้าจอสำเร็จ!",
                    Duration = 2, Icon = "check"
                })
                task.wait(1.5)
            end
            task.wait(0.5)
        end
    end)
end

-- ========================
-- Macro System Logic
-- ========================
-- ระบบดักจับการกดปุ่มเพื่อบันทึก Macro
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not isRecording or gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local timeOffset = tick() - startTime
        table.insert(macroData, {
            KeyCode = input.KeyCode,
            Time = timeOffset
        })
    end
end)

local function startPlayingMacro()
    if #macroData == 0 then
        WindUI:Notify({ Title = "Macro Error", Content = "ยังไม่มีข้อมูล Macro ที่บันทึกไว้", Duration = 3, Icon = "alert-circle" })
        return
    end
    isPlaying = true
    macroThread = task.spawn(function()
        while isPlaying do
            for _, data in ipairs(macroData) do
                if not isPlaying then break end
                task.wait(data.Time - (macroData[_ - 1] and macroData[_ - 1].Time or 0))
                pcall(function()
                    VirtualInputManager:SendKeyEvent(true, data.KeyCode, false, game)
                    task.wait(0.02)
                    VirtualInputManager:SendKeyEvent(false, data.KeyCode, false, game)
                end)
            end
            task.wait(0.1) -- พักจังหวะวนลูป Macro รอบถัดไป
        end
    end)
end

-- ========================
-- Window Setup (Wind UI)
