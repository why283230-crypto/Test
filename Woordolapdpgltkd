-- หาโมเดล NPC เควสจาก workspace.Quests
local function getQuestNpcModel(npcName)
    local questsFolder = workspace:FindFirstChild("Quests")
    if not questsFolder then return nil end
    return questsFolder:FindFirstChild(npcName)
end

local function getQuestNpcPosition(npcName)
    local model = getQuestNpcModel(npcName)
    if not model then return nil end
    local root = model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("RootPart")
        or model.PrimaryPart
    if not root then
        for _, part in ipairs(model:GetDescendants()) do
            if part:IsA("BasePart") then root = part break end
        end
    end
    return root and root.Position
end

-- สแกนหา ProximityPrompt ใต้โมเดล NPC
local function findProximityPrompt(model)
    if not model then return nil end
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            return v
        end
    end
    return nil
end

-- สแกนชื่อมอนสเตอร์ทั้งหมดจาก workspace.ClientEntities
local function scanMobList()
    local newList = {}
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if clientEntities then
        for _, child in ipairs(clientEntities:GetChildren()) do
            if child:IsA("Model") then
                -- คงค่าที่ถูกเลือกไว้เดิม ถ้ามีชื่อซ้ำกัน
                newList[child.Name] = mobList[child.Name] or false
            end
        end
    end
    mobList = newList
    return mobList
end

local function getMobNames()
    local names = {}
    for name, _ in pairs(mobList) do
        table.insert(names, name)
    end
    table.sort(names)
    return names
end

local function getMobPosition(mobName)
    local clientEntities = workspace:FindFirstChild("ClientEntities")
    if not clientEntities then return nil end
    local mobModel = clientEntities:FindFirstChild(mobName)
    if not mobModel then return nil end
    local root = mobModel:FindFirstChild("HumanoidRootPart")
        or mobModel:FindFirstChild("RootPart")
        or mobModel.PrimaryPart
    if not root then
        for _, part in ipairs(mobModel:GetDescendants()) do
            if part:IsA("BasePart") then root = part break end
        end
    end
    return root and root.Position
end

-- 🛠️ [Universal UI Clicker] ฟังก์ชันจำลองการคลิกปุ่ม UI เสมือน (รองรับทุกอุปกรณ์ PC/Mobile)
local function clickButton(button)
    if button:IsA("TextButton") or button:IsA("ImageButton") then
        pcall(function()
            for _, connection in pairs(getconnections(button.MouseButton1Click or button.Activated)) do
                connection:Fire()
            end
        end)
        pcall(function()
            button:SimulateClick()
        end)
    end
end

-- 🛠️ [Universal UI Clicker] สแกนหน้าจอและคลิกปุ่มตามข้อความคีย์เวิร์ด (ชื่อมอนสเตอร์/เควส)
local function autoAcceptQuest(questName)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end

    for _, guiObject in ipairs(playerGui:GetDescendants()) do
        if guiObject:IsA("TextButton") or guiObject:IsA("TextLabel") then
            if guiObject.Text:lower():find(questName:lower()) then
                if guiObject:IsA("TextButton") then
                    clickButton(guiObject)
                    return true
                elseif guiObject.Parent:IsA("TextButton") or guiObject.Parent:IsA("ImageButton") then
                    clickButton(guiObject.Parent)
                    return true
                end
            end
        end
    end
    return false
end

-- พยายาม trigger ProximityPrompt ด้วยทุกวิธีที่เป็นไปได้ (fireproximityprompt ก่อน แล้วค่อย fallback)
local function triggerProximityPrompt(prompt)
    if not prompt then return false end
    local ok = pcall(function()
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            -- จำลองกด KeyboardKeyCode ที่ผูกกับ prompt (ปกติคือ E)
            pressKey(prompt.KeyboardKeyCode)
        end
    end)
    return ok
end

-- พยายามอ่าน progress ของเควส "X/Y" จาก QuestScroll (สแกนทุก category folder แบบไดนามิก ไม่ hardcode ชื่อ)
local function getQuestProgress(questNamePattern)
    local ok, result = pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if not playerGui then return nil end
        local questScroll = playerGui:FindFirstChild("Main")
            and playerGui.Main:FindFirstChild("Pages")
            and playerGui.Main.Pages:FindFirstChild("Quests")
            and playerGui.Main.Pages.Quests:FindFirstChild("Page")
            and playerGui.Main.Pages.Quests.Page:FindFirstChild("Main")
            and playerGui.Main.Pages.Quests.Page.Main:FindFirstChild("Bottom")
            and playerGui.Main.Pages.Quests.Page.Main.Bottom:FindFirstChild("QuestScroll")
        if not questScroll then return nil end

        -- ลูปทุก category folder แบบไดนามิก (ไม่ hardcode ชื่อ เช่น All/Daily/Main/Side/Repeatable)
        for _, categoryFolder in ipairs(questScroll:GetChildren()) do
            if categoryFolder:IsA("Folder") or categoryFolder:IsA("Frame") then
                for _, entry in ipairs(categoryFolder:GetChildren()) do
                    local main = entry:FindFirstChild("Main")
                    local info = main and main:FindFirstChild("Info")
                    local questName = info and info:FindFirstChild("QuestName")
                    if questName and questName.Text and questName.Text:lower():find(questNamePattern:lower()) then
                        local questBar = info:FindFirstChild("QuestBar")
                        local progressFrame = questBar and questBar:FindFirstChild("QuestBarProgress")
                        local progressAmount = progressFrame and progressFrame:FindFirstChild("QuestBarProgressAmount")
                        if progressAmount then
                            return progressAmount.Text -- เช่น "3/8 (37%)"
                        end
                    end
                end
            end
        end
        return nil
    end)
    return ok and result or nil
end

-- เปิดหน้า Quests แบบไม่ให้เห็น (หรือเห็นแว้บๆ) เพื่อ force ให้ QuestScroll อัปเดตข้อมูลใหม่
local function refreshQuestPage()
    pcall(function()
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        local questsPage = playerGui and playerGui:FindFirstChild("Main")
            and playerGui.Main:FindFirstChild("Pages")
            and playerGui.Main.Pages:FindFirstChild("Quests")
        if not questsPage then return end

        local wasVisible = questsPage.Visible
        questsPage.Visible = true   -- trigger ให้หน้าโหลดข้อมูลใหม่
        task.wait(0.15)
        if not wasVisible then
            questsPage.Visible = false
        end
    end)
end

-- ดึงตัวเลข current/max จากข้อความ progress เช่น "3/8 (37%)"
local function parseProgress(progressText)
    if not progressText then return nil, nil end
    local current, max = progressText:match("(%d+)%s*/%s*(%d+)")
    if current and max then
        return tonumber(current), tonumber(max)
    end
    return nil, nil
end

-- ========================
-- [NEW] Auto Quest Logic
-- ========================
local function stopAutoQuest()
    autoQuestEnabled = false
    autoQuestStatus  = "Idle"
    if autoQuestThread then
        task.cancel(autoQuestThread)
        autoQuestThread = nil
    end
end

local function startAutoQuest()
    stopAutoQuest()
    if not selectedQuestNpc then
        WindUI:Notify({ Title = "Error", Content = "Please select a Quest NPC first", Duration = 3, Icon = "alert-circle" })
        return
    end
    if not selectedMob then
        WindUI:Notify({ Title = "Error", Content = "Please select a Mob to farm first", Duration = 3, Icon = "alert-circle" })
        return
    end

    autoQuestEnabled = true
    autoQuestThread = task.spawn(function()
        while autoQuestEnabled do
            -- STEP 1: เทเลพอร์ตไปหา NPC
            autoQuestStatus = "Teleporting to NPC"
            local hrp = getHRP()
            local npcPos = getQuestNpcPosition(selectedQuestNpc)
            if hrp and npcPos then
                hrp.CFrame = CFrame.new(npcPos + Vector3.new(0, 0, 3))
            end
            task.wait(1)
            if not autoQuestEnabled then break end

            -- STEP 2: trigger ProximityPrompt ของ NPC
            autoQuestStatus = "Interacting with NPC"
            local npcModel  = getQuestNpcModel(selectedQuestNpc)
            local prompt     = npcModel and findProximityPrompt(npcModel)
            if prompt then
                triggerProximityPrompt(prompt)
            end
            task.wait(1)
            if not autoQuestEnabled then break end

            -- STEP 3: พยายามกดรับเควสอัตโนมัติด้วยระบบจำลองการกดบนหน้าจอ (สแกนหาตามชื่อมอนสเตอร์ที่เลือกไว้)
            autoQuestStatus = "Accepting Quest (Scanning UI)"
            local clicked = false
            for i = 1, 10 do -- วนลูปหาปุ่มสูงสุด 10 ครั้ง เผื่อ UI ดีเลย์
                if autoAcceptQuest(selectedMob) then
                    clicked = true
                    break
                end
                task.wait(0.2)
            end
            task.wait(0.5)
            if not autoQuestEnabled then break end

            -- STEP 4: บังคับ refresh หน้าเควสเพื่ออ่าน progress ปัจจุบัน
            refreshQuestPage()
            task.wait(0.3)

            -- STEP 5: ไปฟาร์มมอนที่เลือกไว้ จนกว่า progress จะครบ
            autoQuestStatus = "Farming Mobs"
            local farmTimeout = 0
            while autoQuestEnabled do
                refreshQuestPage()
                local progressText = getQuestProgress(selectedMob) or getQuestProgress("")
                local current, max = parseProgress(progressText)

                if current and max and current >= max then
                    break -- เควสครบแล้ว ไปส่งเควสได้
                end

                local mHrp = getHRP()
                local mobPos = getMobPosition(selectedMob)
                if mHrp and mobPos then
                    mHrp.CFrame = CFrame.new(mobPos)
                    farmTimeout = 0
                else
                    farmTimeout = farmTimeout + 1
                    if farmTimeout > 100 then break end -- ป้องกัน loop ค้างถ้าหามอนไม่เจอนานเกินไป
                end
                task.wait(0.3)
            end
            if not autoQuestEnabled then break end

            -- STEP 6: กลับไปส่งเควสที่ NPC เดิม (interact ซ้ำเพื่อจบเควส)
            autoQuestStatus = "Returning to NPC to turn in"
            local hrp2 = getHRP()
            local npcPos2 = getQuestNpcPosition(selectedQuestNpc)
            if hrp2 and npcPos2 then
                hrp2.CFrame = CFrame.new(npcPos2 + Vector3.new(0, 0, 3))
            end
            task.wait(1)
            if not autoQuestEnabled then break end

            local npcModel2 = getQuestNpcModel(selectedQuestNpc)
            local prompt2     = npcModel2 and findProximityPrompt(npcModel2)
            if prompt2 then
                triggerProximityPrompt(prompt2)
            end
            task.wait(1.5)

            -- STEP 7: วนกลับไปรับเควสใหม่อีกรอบ
            autoQuestStatus = "Quest Completed! Restarting..."
            task.wait(0.5)
        end
        autoQuestStatus = "Idle"
    end)
end

