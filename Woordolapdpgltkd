task.wait(0.3)

local QuestTab = Window:Tab({ Title = "Quest System", Icon = "scroll-text" })
local MacroTab = Window:Tab({ Title = "Macro Player", Icon = "activity" })

-- ========================
-- Quest UI
-- ========================
QuestTab:Dropdown({
    Title  = "Select NPC Quest",
    Desc   = "เลือก NPC เควสที่คุณต้องการทำงานร่วมด้วย",
    Icon   = "user",
    Values = questNpcNames,
    Value  = selectedQuestNpc,
    Callback = function(selected)
        selectedQuestNpc = selected
    end,
})

QuestTab:Dropdown({
    Title  = "Select Quest Name",
    Desc   = "เลือกคีย์เวิร์ดชื่อเควสให้บอทสแกนกดอัตโนมัติบนหน้าจอ",
    Icon   = "list",
    Values = questList,
    Value  = selectedQuest,
    Callback = function(selected)
        selectedQuest = selected
    end,
})

QuestTab:Divider()

QuestTab:Toggle({
    Title = "Auto Accept Quest (UI Scan)",
    Desc  = "เปิดระบบสแกนหาตัวหนังสือชื่อเควสเพื่อกดคลิกออโต้บนหน้าจอ",
    Icon  = "mouse-pointer",
    Value = false,
    Callback = function(state)
        autoQuestEnabled = state
        if state then
            startQuestLoop()
            WindUI:Notify({ Title = "Quest System", Content = "เริ่มระบบสแกนรับเควสแล้ว", Duration = 3, Icon = "play" })
        else
            if questThread then task.cancel(questThread) end
            WindUI:Notify({ Title = "Quest System", Content = "ปิดระบบสแกนรับเควสแล้ว", Duration = 3, Icon = "x" })
        end
    end,
})

-- ========================
-- Macro UI
-- ========================
MacroTab:Toggle({
    Title = "Record Macro",
    Desc  = "เปิดสวิตช์แล้วกดปุ่มสกิล/แป้นพิมพ์เพื่อบันทึกจังหวะการกดไว้",
    Icon  = "circle-dot",
    Value = false,
    Callback = function(state)
        isRecording = state
        if state then
            macroData = {} -- รีเซ็ตข้อมูลเก่า
            startTime = tick()
            WindUI:Notify({ Title = "Macro", Content = "กำลังบันทึกการกดปุ่ม...", Duration = 3, Icon = "circle-dot" })
        else
            WindUI:Notify({ Title = "Macro", Content = "บันทึกข้อมูลสำเร็จ ("..#macroData.." ปุ่ม)", Duration = 3, Icon = "save" })
        end
    end,
})

MacroTab:Toggle({
    Title = "Play Macro (Loop)",
    Desc  = "รันปุ่มกดตามจังหวะเวลาที่คุณอัดไว้ซ้ำๆ อัตโนมัติ",
    Icon  = "play",
    Value = false,
    Callback = function(state)
        if state then
            startPlayingMacro()
        else
            isPlaying = false
            if macroThread then task.cancel(macroThread) macroThread = nil end
            WindUI:Notify({ Title = "Macro", Content = "หยุดการเล่น Macro แล้ว", Duration = 3, Icon = "pause" })
        end
    end,
})

MacroTab:Button({
    Title = "Clear Macro Data",
    Desc  = "ล้างข้อมูล Macro ที่เคยกดบันทึกไว้ทั้งหมดเพื่อบันทึกใหม่",
    Icon  = "trash-2",
    Callback = function()
        macroData = {}
        WindUI:Notify({ Title = "Macro", Content = "ล้างข้อมูลเรียบร้อยแล้ว", Duration = 3, Icon = "trash-2" })
    end,
})

-- ========================
-- Floating Button (Fixed Version - ห้ามแก้โค้ดส่วนนี้)
-- ========================
local FloatGui    = Instance.new("ScreenGui")
local FloatBtn    = Instance.new("TextButton")
local FloatCorner = Instance.new("UICorner")
local FloatStroke = Instance.new("UIStroke")

FloatGui.Name           = "MonHubFloat"
FloatGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
FloatGui.ResetOnSpawn   = false
FloatGui.DisplayOrder   = 999

local coreGui = game:GetService("CoreGui")
pcall(function() FloatGui.Parent = coreGui end)
if not FloatGui.Parent or FloatGui.Parent ~= coreGui then
    FloatGui.Parent = LocalPlayer:WaitForChild("PlayerGui")
end

FloatBtn.Name             = "ToggleBtn"
FloatBtn.Parent           = FloatGui
FloatBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
FloatBtn.Position         = UDim2.new(0.05, 0, 0.2, 0)
FloatBtn.Size             = UDim2.fromOffset(52, 52)
FloatBtn.Text             = "M"
FloatBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
FloatBtn.Font             = Enum.Font.GothamBold
FloatBtn.TextSize         = 24
FloatBtn.Active           = true
FloatBtn.ZIndex           = 99999
FloatBtn.Visible          = false

FloatCorner.CornerRadius = UDim.new(0, 14)
FloatCorner.Parent       = FloatBtn

FloatStroke.Color     = Color3.fromRGB(0, 150, 255)
FloatStroke.Thickness = 2.5
FloatStroke.Parent    = FloatBtn

local dragging  = false
local dragInput = nil
local dragStart = nil
local startPos  = nil

FloatBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging  = true
        dragStart = input.Position
        startPos  = FloatBtn.Position
    end
end)

FloatBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

FloatBtn.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and dragInput and input == dragInput then
        local delta = input.Position - dragStart
        FloatBtn.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

local menuVisible = true

local function toggleMenu()
    menuVisible = not menuVisible
    if menuVisible then
        FloatBtn.Visible = false
        pcall(function()
            if Window.Show then Window:Show()
            elseif Window.Open then Window:Open()
            elseif Window.Toggle then Window:Toggle() end
        end)
    else
        FloatBtn.Visible = true
        pcall(function()
            if Window.Hide then Window:Hide()
            elseif Window.Close then Window:Close()
            elseif Window.Toggle then Window:Toggle() end
        end)
    end
end

FloatBtn.MouseButton1Click:Connect(function()
    if dragStart and startPos then
        local curPos = FloatBtn.Position
        local dx = math.abs(curPos.X.Offset - startPos.X.Offset)
        local dy = math.abs(curPos.Y.Offset - startPos.Y.Offset)
        if dx > 5 or dy > 5 then return end
    end
    menuVisible = false
    toggleMenu()
end)

task.spawn(function()
    task.wait(1)
    while true do
        task.wait(0.4)
        pcall(function()
            local currentUiVisible = false
            local mainFrame = Window.Main or Window.Frame or Window.Container
            if mainFrame then
                currentUiVisible = mainFrame.Visible
            else
                for _, gui in ipairs(coreGui:GetChildren()) do
                    if (gui.Name == "WindUI" or gui.Name == "MonHubSimple") and gui:IsA("ScreenGui") then
                        currentUiVisible = gui.Enabled
                        break
                    end
                end
            end
            
            menuVisible = currentUiVisible
            FloatBtn.Visible = not currentUiVisible
        end)
    end
end)

WindUI:Notify({
    Title    = "MonHub Loaded!",
    Content  = "ระบบอัด Macro และสแกนเควสพร้อมทำงานแล้วครับ",
    Duration = 5,
    Icon     = "check",
})
