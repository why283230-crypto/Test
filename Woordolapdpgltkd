local function stopAutoEquip()
    autoEquipEnabled = false
    if strokeConn then
        strokeConn:Disconnect()
        strokeConn = nil
    end
    if autoEquipThread then
        task.cancel(autoEquipThread)
        autoEquipThread = nil
    end
end

local function doEquip()
    if isEquipping then return end
    isEquipping = true
    local kc = slotKeyCode[selectedSlot]
    if kc then
        pressKey(kc)
        task.wait(0.4)
    end
    isEquipping = false
end

local function startAutoEquip()
    stopAutoEquip()
    if not selectedSlot then return end
    autoEquipEnabled = true

    autoEquipThread = task.spawn(function()
        local stroke = nil
        while autoEquipEnabled do
            stroke = getSlotStroke()
            if stroke then break end
            task.wait(0.5)
        end
        if not stroke then return end

        if isStrokeBlack(stroke) then
            doEquip()
        end

        strokeConn = stroke:GetPropertyChangedSignal("Color"):Connect(function()
            if not autoEquipEnabled then return end
            if isStrokeBlack(stroke) then
                doEquip()
            end
        end)
    end)
end

